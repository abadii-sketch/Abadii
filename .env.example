# PostgreSQL connection string. Works with Neon, Supabase, Railway, or any Postgres host.
DATABASE_URL="postgresql://user:password@host:5432/abadii?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Your deployed URL. Use http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"
